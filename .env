# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# The chat ID of your shillit Telegram group (bot must be added as admin)
# Get this by adding the bot to the group, sending a message, and checking
# https://api.telegram.org/bot<token>/getUpdates
GROUP_CHAT_ID=

# Your personal Telegram user ID — receives private founder intelligence DMs
# Get yours from @userinfobot on Telegram
FOUNDER_USER_ID=

# --- Pulse tuning (optional, sensible defaults used if blank) ---
PULSE_MIN_INTERVAL_MINUTES=240
PULSE_MAX_INTERVAL_MINUTES=1440
PULSE_FIRE_CHANCE=0.4

# --- Role decay (optional) ---
ROLE_DECAY_DAYS=30

# --- Raid system tuning (optional) ---
# Title required to post a comment-raid card (Founder always bypasses this).
# Set to "Lurker" to let anyone post while the group is still small, then
# raise it later (e.g. back to "Diamond Hand") as the group grows — no
# code changes needed, just edit this and restart.
RAID_REQUIRED_TITLE=Diamond Hand

# Votes needed before an X comment card unlocks into a raid box
RAID_VOTE_THRESHOLD=5

# Default number of raid joins needed to fill the progress bar
RAID_DEFAULT_TARGET=10

# How long a vote card stays open before it's swept away if it never
# reaches the vote threshold (minutes)
CARD_EXPIRY_MINUTES=180

# After this many new messages pass through the chat, the single leading
# voting card and the single leading raid box (if any) get reposted so
# they don't get buried in a busy chat. A quiet chat simply never reaches
# this count, so this never spams an inactive group.
REPOST_EVERY_N_MESSAGES=15

# --- Random status spotlight (optional) ---
SPOTLIGHT_MIN_INTERVAL_MINUTES=360
SPOTLIGHT_MAX_INTERVAL_MINUTES=1440
SPOTLIGHT_FIRE_CHANCE=0.3
