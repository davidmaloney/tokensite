  GNU nano 7.2                                                                                                                 .env                                                                                                                          
# ─── USER CONFIGURATION (required) ───────────────────────────────
DOMAIN=
SOLANA_RPC_URL=

TREASURY_WALLET=
NODE_ENV=production

# ─── OWNER / TESTING ──────────────────────────────────────────────
OWNER_ACCESS_CODE=
MOCK_MODE=false

# ─── ADMIN MODERATION ─────────────────────────────────────────────
# Comma-separated slugs to permanently delete/block
DELETE_SLUGS=api, admin, dashboard, app, mail, email, ftp, ssh, sftp, cdn, assets, static, media, files, uploads, img, images, video, videos, dev, development, test, testing, stage, staging, prod, production, internal, intranet, vpn, support, help, sta>

# ─── CLOUDFLARE (wildcard DNS — optional if managed manually) ─────
# CF_API_TOKEN=
# CF_ZONE_ID=

# ─── INTERNAL (auto-managed — do not set manually) ────────────────
# WALLET_AUTH_SECRET  ← auto-generated on first boot
POSTGRES_PASSWORD=
DATABASE_URL=

PROMO_CODE=
