# ─── USER CONFIGURATION (required) ───────────────────────────────
DOMAIN=tokensite.fun
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TREASURY_WALLET=YOUR_TREASURY_WALLET_ADDRESS_HERE
NODE_ENV=production

# ─── OWNER / TESTING ──────────────────────────────────────────────
OWNER_ACCESS_CODE=CHANGE_THIS_TO_A_SECRET_CODE
MOCK_MODE=false

# ─── ADMIN MODERATION ─────────────────────────────────────────────
# Comma-separated slugs to permanently delete/block
DELETE_SLUGS=

# ─── CLOUDFLARE (wildcard DNS — optional if managed manually) ─────
# CF_API_TOKEN=your_cloudflare_api_token
# CF_ZONE_ID=your_cloudflare_zone_id

# ─── INTERNAL (auto-managed — do not set manually) ────────────────
# WALLET_AUTH_SECRET  ← auto-generated on first boot
